# 复制为 control.env；所有 CHANGE_ME 值必须替换。
CONTROL_BIND_ADDRESS=0.0.0.0
CONTROL_HTTP_PORT=80
CONTROL_HTTPS_PORT=443
CONTROL_GRPC_PORT=50051
CONTROL_MINIO_PORT=9000

POSTGRES_DB=mini_drop
POSTGRES_USER=mini_drop
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

MINIO_ACCESS_KEY=mini_drop_worker
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=mini-drop
# 必须是 Worker 可访问的 Control 地址；浏览器下载已走 Server，不依赖此端点。
MINIO_PUBLIC_ENDPOINT=http://10.0.0.10:9000
MINIO_PUBLIC_SECURE=0

MINI_DROP_API_KEY=CHANGE_ME_API_KEY
MINI_DROP_GRPC_TOKEN=CHANGE_ME_SHARED_RANDOM_GRPC_TOKEN
MINI_DROP_ALLOWED_SERVICES=

# AI 可先关闭完成基础链路联调，再填入 Provider 配置。
MINI_DROP_AI_ENABLED=off
MINI_DROP_AI_PROVIDER=deepseek
MINI_DROP_AI_BASE_URL=https://api.deepseek.com
MINI_DROP_AI_API_KEY=
MINI_DROP_AI_MODEL=deepseek-v4-flash
