# 每台 Worker 各复制一份为 worker.env。
AGENT_ID=linux-worker-1
AGENT_IP_ADDR=10.0.0.21
AGENT_GRPC_ADDR=10.0.0.10:50051
AGENT_HEARTBEAT_INTERVAL_SEC=5
# 证书 SAN 与连接地址不一致时才填写，例如 control.internal。
AGENT_GRPC_TLS_SERVER_NAME=

MINI_DROP_GRPC_TOKEN=CHANGE_ME_SHARED_RANDOM_GRPC_TOKEN

MINIO_ENDPOINT=http://10.0.0.10:9000
MINIO_ACCESS_KEY=mini_drop_worker
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=mini-drop
MINIO_SECURE=0
