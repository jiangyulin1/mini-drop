# Mini-Drop 环境变量模板
# 复制为 .env 后根据需要修改，不要提交真实密钥

MINI_DROP_ENV=dev

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8191
MINI_DROP_API_AUTH_ENABLED=0
MINI_DROP_API_KEY=
MINI_DROP_ARTIFACT_ROOT=/tmp/mini-drop

# PostgreSQL
DATABASE_URL=postgresql+psycopg://mini_drop:mini_drop@postgres:5432/mini_drop

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=mini_drop
MINIO_SECRET_KEY=mini_drop_secret
MINIO_BUCKET=mini-drop
MINIO_AUTO_CREATE_BUCKET=1

# AI Provider (可选，兼容 OpenAI / DeepSeek / 任意 OpenAI-compatible 服务)
MINI_DROP_AI_ENABLED=full
MINI_DROP_AI_PROVIDER=deepseek
MINI_DROP_AI_BASE_URL=https://api.deepseek.com
MINI_DROP_AI_API_KEY=
MINI_DROP_AI_MODEL=deepseek-chat
MINI_DROP_NLP_ENABLED=true
MINI_DROP_RCA_ENABLED=true
MINI_DROP_SUMMARIZE_ENABLED=true

# DeepSeek legacy aliases（仍兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Agent
AGENT_ID=agent_local_demo
AGENT_GRPC_ADDR=server:50051
AGENT_HEARTBEAT_INTERVAL_SEC=5
