# Mini-Drop 环境变量模板
# 复制为 .env 后根据需要修改，不要提交真实密钥
#
# 默认配置面向本地 demo，可直接 docker compose up + make demo。
# 生产/公网演示前请开启认证并设置随机密钥：
#   MINI_DROP_API_AUTH_ENABLED=1
#   MINI_DROP_GRPC_AUTH_ENABLED=1
#   MINI_DROP_API_KEY=<your-random-key>
#   MINI_DROP_GRPC_TOKEN=<your-random-token>

MINI_DROP_ENV=dev

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8191
MINI_DROP_API_AUTH_ENABLED=0
MINI_DROP_API_KEY=
MINI_DROP_ARTIFACT_ROOT=/tmp/mini-drop
MINI_DROP_GRPC_AUTH_ENABLED=0
MINI_DROP_GRPC_TOKEN=

# PostgreSQL
DATABASE_URL=postgresql+psycopg://mini_drop:mini_drop@postgres:5432/mini_drop

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mini_drop
MINIO_SECRET_KEY=mini_drop_secret
MINIO_BUCKET=mini-drop
MINIO_AUTO_CREATE_BUCKET=1
MINIO_SECURE=0

# AI Provider (可选，兼容 OpenAI / DeepSeek / 任意 OpenAI-compatible 服务)
MINI_DROP_AI_ENABLED=full
MINI_DROP_AI_PROVIDER=deepseek
MINI_DROP_AI_BASE_URL=https://api.deepseek.com/v1
MINI_DROP_AI_API_KEY=
MINI_DROP_AI_MODEL=deepseek-chat
MINI_DROP_NLP_ENABLED=true
MINI_DROP_RCA_ENABLED=true
MINI_DROP_SUMMARIZE_ENABLED=true

# AI 集群诊断资源范围（逗号分隔；留空表示不额外限制，生产建议显式配置）
MINI_DROP_ALLOWED_SERVICES=

# DeepSeek legacy aliases（仍兼容）
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Agent
AGENT_ID=agent_local_demo
AGENT_GRPC_ADDR=server:50051
AGENT_HEARTBEAT_INTERVAL_SEC=5
AGENT_UPLOAD_ARTIFACTS=0

# ── ChatOps（可选，企业 IM / QQ 群通知）─────────────────
# 支持的 provider：wecom / feishu / dingtalk / slack / qqbot
#
# QQ 机器人（qqbot）推荐使用 WebSocket 模式，免配置开放端口：
#   MINI_DROP_CHATOPS_ENABLED=1
#   MINI_DROP_CHATOPS_PROVIDER=qqbot
#   MINI_DROP_CHATOPS_WEBHOOK_URL=ws://127.0.0.1:5701
#   MINI_DROP_QQBOT_TARGET_TYPE=group
#   MINI_DROP_QQBOT_TARGET_ID=<YOUR_QQ_GROUP_ID>
#
# 企业微信 / 飞书 / 钉钉 / Slack 使用 Webhook URL：
#   MINI_DROP_CHATOPS_ENABLED=1
#   MINI_DROP_CHATOPS_PROVIDER=wecom
#   MINI_DROP_CHATOPS_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
#
# 安装可选依赖：pip install -e ".[chatops]"
#───────────────────────────────────────────────────────────
MINI_DROP_CHATOPS_ENABLED=0
MINI_DROP_CHATOPS_PROVIDER=qqbot
MINI_DROP_CHATOPS_WEBHOOK_URL=ws://127.0.0.1:5701
MINI_DROP_QQBOT_TARGET_TYPE=group
MINI_DROP_QQBOT_TARGET_ID=
